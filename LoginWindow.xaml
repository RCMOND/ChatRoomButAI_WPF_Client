<Window x:Class="ChatClientWpf.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录" Height="450" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Background="White">
        <Border VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
            <StackPanel Width="300">
                <TextBlock Text="登录聊天室" FontSize="24" FontWeight="Bold" 
                           Foreground="#5865F2" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBox x:Name="txtLoginUser" Margin="0,5" Padding="10" Height="36"/>
                <PasswordBox x:Name="txtLoginPassword" Margin="0,5" Padding="10" Height="36"/>
                <Button Content="登录" Height="36" Background="#5865F2" Foreground="White" 
                        FontWeight="Bold" Click="BtnLogin_Click" Margin="0,10"/>
                <TextBlock x:Name="txtError" Foreground="Red" HorizontalAlignment="Center" Margin="0,5"/>
                <TextBlock HorizontalAlignment="Center">
                    <Hyperlink Click="BtnRegister_Click">注册新账号</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>