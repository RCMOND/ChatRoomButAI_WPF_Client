<Window x:Class="ChatClientWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="聊天室" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing"
        Background="#F5F5F5">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="#5865F2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <Border.Effect><DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.2"/></Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#4752C4"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#3C45A5"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="IconButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="4" CornerRadius="4">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#E0E0E0"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="MessageTemplate">
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <Image Source="{Binding Avatar}" Width="30" Height="30" Stretch="UniformToFill" Margin="0,0,5,0">
                    <Image.Clip>
                        <EllipseGeometry Center="15,15" RadiusX="15" RadiusY="15"/>
                    </Image.Clip>
                </Image>
                <StackPanel>
                    <TextBlock Text="{Binding User}" FontWeight="Bold" FontSize="12" Foreground="#2C3E50" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="13" Foreground="#34495E"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 公告栏区域（包含用户信息栏） -->
        <StackPanel Grid.Row="0">
            <Border Background="White" Padding="5" CornerRadius="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <Image x:Name="imgMyAvatar" Width="36" Height="36" Margin="5" Cursor="Hand" MouseDown="BtnAvatar_Click"/>
                        <TextBlock x:Name="txtMyUsername" VerticalAlignment="Center" FontWeight="Bold" Foreground="#2C3E50" FontSize="14" Margin="5,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="退出" Style="{StaticResource ModernButton}" Background="#EF4444" Foreground="White" Width="60" Height="30" FontSize="12" FontWeight="SemiBold" Margin="5,0" Click="BtnLogout_Click"/>
                </Grid>
            </Border>
            <Border x:Name="brdAdminAnnouncement" Background="#FEE2E2" CornerRadius="0" Padding="8" Margin="0" Visibility="Collapsed">
                <DockPanel>
                    <TextBlock Text="📢 " VerticalAlignment="Center" Foreground="#DC2626"/>
                    <TextBlock x:Name="txtAdminAnnouncement" TextWrapping="Wrap" DockPanel.Dock="Left" Foreground="#7F1D1D"/>
                    <Button Content="✕" Background="Transparent" BorderThickness="0" Foreground="#7F1D1D" Click="HideAdminAnnouncement_Click" HorizontalAlignment="Right"/>
                </DockPanel>
            </Border>
            <Border x:Name="brdAnnouncement" Background="#FFF3CD" CornerRadius="0" Padding="8" Margin="0" Visibility="Collapsed">
                <DockPanel>
                    <TextBlock Text="📢 " VerticalAlignment="Center" Foreground="#856404"/>
                    <TextBlock x:Name="txtAnnouncement" TextWrapping="Wrap" DockPanel.Dock="Left" Foreground="#856404"/>
                    <Button Content="✕" Background="Transparent" BorderThickness="0" Foreground="#856404" Click="HideAnnouncement_Click" HorizontalAlignment="Right"/>
                </DockPanel>
            </Border>
        </StackPanel>

        <!-- 音乐控制栏（始终显示） -->
        <Border x:Name="brdMusicBar" Grid.Row="1" Background="#2C2F33" Padding="8,5" Margin="0" CornerRadius="0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="🎵" Foreground="White" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBlock x:Name="txtCurrentSong" Text="未播放" Foreground="#B9BBBE" VerticalAlignment="Center" Margin="10,0" MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnPlayPause" Content="▶️" Style="{StaticResource IconButton}" Foreground="White" Click="BtnPlayPause_Click"/>
                    <Button Content="⏭" Style="{StaticResource IconButton}" Foreground="White" Click="BtnNextTrack_Click"/>
                    <Button x:Name="btnCycleMode" Content="🔁" Style="{StaticResource IconButton}" Foreground="White" Click="BtnCycleMode_Click"/>
                    <Button Content="⏹" Style="{StaticResource IconButton}" Foreground="White" Click="BtnStopMusic_Click"/>
                    <Button Content="📋" Style="{StaticResource IconButton}" Foreground="White" Click="BtnShowPlaylist_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 主聊天区域 -->
        <Grid Grid.Row="2" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>
            <ListBox x:Name="lbMessages" Grid.Column="0" Margin="10,10,5,10" Background="Transparent" BorderThickness="0"
                     ItemTemplate="{StaticResource MessageTemplate}" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
            <GroupBox Header="在线用户" Grid.Column="1" Margin="5,10,10,10" Foreground="#5865F2" FontWeight="Bold" BorderBrush="#E5E7EB" Background="White" BorderThickness="1" Padding="5">
                <ListBox x:Name="lbOnlineUsers" SelectionChanged="LbOnlineUsers_SelectionChanged" Background="Transparent" BorderThickness="0"/>
            </GroupBox>
        </Grid>

        <!-- 底部输入区 -->
        <Grid Grid.Row="3" Margin="10,5,10,10">
            <ProgressBar x:Name="pbUpload" Grid.Row="0" Minimum="0" Maximum="100" Height="6" Visibility="Collapsed" Foreground="#5865F2" Background="#E5E7EB"/>
            <DockPanel Grid.Row="1" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="0,0,10,0">
                    <Button Content="😊" Style="{StaticResource IconButton}" Click="BtnEmoji_Click"/>
                    <Button Content="🖼️" Style="{StaticResource IconButton}" Click="BtnUploadImage_Click" Margin="5,0"/>
                    <Button Content="📎" Style="{StaticResource IconButton}" Click="BtnUploadFile_Click" Margin="5,0"/>
                    <Button Content="🗑️" Style="{StaticResource IconButton}" Click="BtnClearMessages_Click" Margin="5,0" ToolTip="清除本地聊天记录"/>
                </StackPanel>
                <TextBox x:Name="txtMessage" KeyDown="TxtMessage_KeyDown" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                <Button x:Name="btnSend" Content="发送" Style="{StaticResource ModernButton}" Width="70" Height="36" Click="BtnSend_Click"/>
            </DockPanel>
        </Grid>
    </Grid>
</Window>